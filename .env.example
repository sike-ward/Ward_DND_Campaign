# =============================================================================
# Ward DND AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# ENVIRONMENT SYSTEM
# ------------------
# APP_ENV controls which environment is active. The config loader will:
#   1. Load .env (shared secrets — this file)
#   2. Load .env.{APP_ENV} if it exists (environment-specific overrides)
#
# Supported values: development (default), production, test
# Set in your shell:  $env:APP_ENV="production"  (PowerShell)
#                     export APP_ENV=production    (bash)
#
# Create .env.development, .env.production, or .env.test alongside this file
# for per-environment overrides. All are gitignored.
# =============================================================================

# Which environment to run (development | production | test)
APP_ENV=development

# --- AI ---
OPENAI_API_KEY=sk-proj-...

# --- Admin account (first launch only) ---
# If ADMIN_PASSWORD is not set, a secure random password is generated and
# printed to the console once. Set these here so you control the credentials.
# Never commit your actual .env file — it is gitignored.
ADMIN_EMAIL=admin@warddnd.app
ADMIN_PASSWORD=change-me-to-something-strong

# --- Optional overrides (defaults come from settings.json) ---
# VAULT_PATH=C:/Users/YourName/Obsidian
# COMPLETION_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small
# LOG_LEVEL=DEBUG

# --- Crash report emails (sent to developer when app crashes) ---
# Use a Gmail App Password (not your real password):
#   Google Account > Security > 2-Step Verification > App Passwords
# CRASH_REPORT_SMTP_HOST=smtp.gmail.com
# CRASH_REPORT_SMTP_PORT=587
# CRASH_REPORT_SMTP_USER=your-gmail@gmail.com
# CRASH_REPORT_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# CRASH_REPORT_TO_EMAIL=your-email@example.com
